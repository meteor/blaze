{
  "name": "blaze-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docs:init": "ln -sf ../*.md source/repo/",
    "docs:dev": "vitepress dev",
    "docs:build": "vitepress build",
    "docs:preview": "vitepress preview",
    "docs:api": "jsdoc2md --no-gfm -m none -g none ../packages/blaze/*.js > source/api/blaze.md "
  },
  "devDependencies": {
    "jsdoc": "^4.0.5",
    "jsdoc-to-markdown": "^9.1.3",
    "vitepress": "^2.0.0-alpha.16"
  }
}
